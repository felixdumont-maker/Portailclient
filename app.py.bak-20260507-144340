            if not assets_folder_id:
                return old_url
            try:
                safe_name = secure_filename(file.filename)
                tmp = tempfile.NamedTemporaryFile(delete=False, suffix=f'.{ext}')
                file.save(tmp.name)
                tmp.close()
                file_id, _ = upload_file(tmp.name, safe_name, assets_folder_id)
